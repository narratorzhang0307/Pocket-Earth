# 将本文件另存为 .env 并填入下面两个 key

# Mapbox access token（地图底图）。申请：https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=your_mapbox_access_token_here

# DeepSeek API key（agent 的大脑，只在服务端用，不进前端 bundle）。
# 不填则 agent 走规则 fallback，UI 照常工作。申请：https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# 端侧模型（ollama 本机后端，做选歌 / 选图 / 分类 / 嵌入 / 视觉打标）。
# 不填用默认；没装 ollama 时自动走规则兜底。部署见 frost-agent/edge/README.md
OLLAMA_URL=http://localhost:11434
EDGE_MODEL=qwen3:0.6b
EDGE_VISION_MODEL=qwen2.5vl:3b
